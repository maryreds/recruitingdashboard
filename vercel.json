{
  "framework": null,
  "buildCommand": "node check.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/data.js": {
      "maxDuration": 30
    },
    "api/enhance-cv.js": {
      "maxDuration": 60
    },
    "api/cover-letter.js": {
      "maxDuration": 60
    },
    "api/candidate-match.js": {
      "maxDuration": 90
    },
    "api/export-docx.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
